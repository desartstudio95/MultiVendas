{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "products": {
      "title": "Product",
      "description": "Product listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "delivery": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "draft"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "price", "category", "status", "createdAt", "updatedAt"]
    },
    "orders": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "delivered", "cancelled"] },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "status", "amount", "paymentMethod", "createdAt"]
    },
    "notifications": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "message", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "reviews": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "messages": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/products/{productId}": {
      "schema": "products",
      "description": "Product listing document"
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "Order document"
    },
    "/notifications/{notificationId}": {
      "schema": "notifications",
      "description": "Notification document"
    },
    "/reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Review document"
    },
    "/messages/{messageId}": {
      "schema": "messages",
      "description": "Message document"
    }
  }
}
